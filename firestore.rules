rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated or specific
    // Fields:
    //   - name: string
    //   - description: string
    //   - price: number
    //   - imageUrl: string
    //   - reactions: map (emoji -> number)
    //
    // Collection: comments
    // Document ID: auto-generated
    // Fields:
    //   - productId: string
    //   - text: string
    //   - author: string
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function isAdmin() {
      return request.auth != null && (request.auth.token.email == 'luizhenriquemachado1602@gmail.com' || request.auth.token.email == 'genaina0011111@gmail.com');
    }

    // Domain Validators
    function isValidProduct() {
      let allowedFields = ['name', 'description', 'price', 'imageUrl', 'imageUrls', 'reactions', 'isPromo', 'oldPrice'];
      return request.resource.data.keys().hasOnly(allowedFields) &&
             validStringLength('name', 1, 100) &&
             validStringLength('description', 1, 1000) &&
             isPositive('price') &&
             (!('imageUrl' in request.resource.data) || validStringLength('imageUrl', 0, 1048487)) &&
             (!('imageUrls' in request.resource.data) || (request.resource.data.imageUrls is list && request.resource.data.imageUrls.size() <= 3)) &&
             request.resource.data.reactions is map &&
             (!('isPromo' in request.resource.data) || request.resource.data.isPromo is bool) &&
             (!('oldPrice' in request.resource.data) || (request.resource.data.oldPrice is number && request.resource.data.oldPrice >= 0));
    }

    function isValidComment() {
      return hasOnlyAllowedFields(['productId', 'text', 'author', 'createdAt']) &&
             validStringLength('productId', 1, 100) &&
             validStringLength('text', 1, 500) &&
             validStringLength('author', 1, 50) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidReactionUpdate() {
      // Only the 'reactions' field can be changed
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(['reactions']) &&
             request.resource.data.reactions is map;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct();
      allow delete: if isAdmin();
      allow update: if isAdmin() || isValidReactionUpdate();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isValidComment();
      allow update: if false;
      allow delete: if false;
    }
  }
}
