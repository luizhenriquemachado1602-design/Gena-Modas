{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the store",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the product"
        },
        "description": {
          "type": "string",
          "description": "The description of the product"
        },
        "price": {
          "type": "number",
          "description": "The price of the product"
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the product image"
        },
        "reactions": {
          "type": "object",
          "description": "A map of emoji to reaction count"
        }
      },
      "required": ["name", "description", "price", "imageUrl"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a product",
      "type": "object",
      "properties": {
        "productId": {
          "type": "string",
          "description": "The ID of the product this comment belongs to"
        },
        "text": {
          "type": "string",
          "description": "The text of the comment"
        },
        "author": {
          "type": "string",
          "description": "The author of the comment"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the comment was created"
        }
      },
      "required": ["productId", "text", "author", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "The products collection"
    },
    "/comments/{commentId}": {
      "schema": {
        "$ref": "#/entities/Comment"
      },
      "description": "The comments collection"
    }
  }
}
